        </article>

        <!-- POLÍTICA DE PRIVACIDAD -->
        <article class="legal-content" id="content-privacidad">
          <h2 class="legal-title">POLÍTICA DE PRIVACIDAD</h2>
          <p class="legal-subtitle">
            PROTECCIÓN DE DATOS PERSONALES (RGPD / LOPDGDD)
