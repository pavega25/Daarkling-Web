---
import Social from "./Social.astro";
---

<style>
  footer.footer {
    position: relative;
    background-color: #0d0d0d; /* Reemplaza por el color exacto de tu fondo de footer */
    color: #ffffff;
    padding-top: 2rem;
  }

  /* Posicionamiento del SVG de rebote */
  .footer-bounce-svg {
    position: absolute;
    top: -80px; /* Ajusta la altura del saliente según el diseño */
    left: 0;
    width: 100%;
    height: 80px;
    pointer-events: none; /* Para evitar interferir con clics */
    overflow: visible;
  }

  /* El relleno del vector debe coincidir con el background del footer */
  #bouncy-path {
    fill: #0d0d0d; /* Mismo color de fondo del footer */
  }

  .footer-content {
    position: relative;
    z-index: 2;
  }
  /* Estilos para los botones del footer */
  .legal-link {
    background: none;
    border: none;
    color: inherit;
    font: inherit;
    cursor: pointer;
    padding: 0;
    text-decoration: none;
    text-underline-offset: 4px;
    text-align: left;
  }

  /* Modal Overlay (Fondo negro) */
  .legal-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(0, 0, 0, 0.92);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    opacity: 0;
    pointer-events: none;
    backdrop-filter: blur(5px);
  }

  .legal-modal-overlay.open {
    pointer-events: auto;
  }

  /* Contenedor principal de la Modal */
  .legal-modal-container {
    background-color: #000000;
    border: 1px solid #333333;
    border-radius: 0 !important; /* Estricto: sin bordes redondeados */
    width: 100%;
    max-width: 750px;
    max-height: 85vh;
    position: relative;
    display: flex;
    flex-direction: column;
    box-shadow: 0 0 30px rgba(0, 0, 0, 0.8);
  }

  /* Botón de cierre */
  .legal-modal-close {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    background: transparent;
    border: none;
    color: #ffffff;
    font-size: 2.2rem;
    font-weight: 200;
    cursor: pointer;
    line-height: 1;
    z-index: 10;
    border-radius: 0 !important;
    transition: opacity 0.2s;
  }

  .legal-modal-close:hover {
    opacity: 0.6;
  }

  /* Cuerpo con scroll personalizado */
  .legal-modal-body {
    padding: 3rem 2.5rem;
    overflow-y: auto;
    color: #ffffff;
    font-family: "Elms Sans", sans-serif;
  }

  /* Scrollbar estilizada recta */
  .legal-modal-body::-webkit-scrollbar {
    width: 4px;
  }

  .legal-modal-body::-webkit-scrollbar-track {
    background: #0a0a0a;
  }

  .legal-modal-body::-webkit-scrollbar-thumb {
    background: #333333;
    border-radius: 0 !important;
  }

  /* Artículos dentro de la modal */
  .legal-content {
    display: none;
  }

  .legal-content.active {
    display: block;
  }

  /* Jerarquía Tipográfica con 'Elms Sans' (Pesos variables de 100 a 900) */
  .legal-title {
    font-family: "Elms Sans", sans-serif;
    font-weight: 900; /* Peso máximo para títulos principales */
    font-size: 2rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
    color: #ffffff;
  }

  .legal-subtitle {
    font-family: "Elms Sans", sans-serif;
    font-weight: 200; /* Peso ligero para subtítulos */
    font-size: 0.85rem;
    letter-spacing: 1.5px;
    color: #a0a0a0;
    margin-bottom: 2rem;
    border-bottom: 1px solid #222222;
    padding-bottom: 0.75rem;
  }

  .legal-section-title {
    font-family: "Elms Sans", sans-serif;
    font-weight: 700; /* Peso marcado para secciones */
    font-size: 1.1rem;
    letter-spacing: 1px;
    margin-top: 1.8rem;
    margin-bottom: 0.5rem;
    color: #ffffff;
  }

  .legal-text {
    font-family: "Elms Sans", sans-serif;
    font-weight: 300; /* Peso regular fino para texto base */
    font-size: 0.95rem;
    line-height: 1.6;
    color: #d1d1d1;
    margin-bottom: 1rem;
  }

  .legal-text strong {
    font-weight: 600;
    color: #ffffff;
  }

  .legal-footer-note {
    font-family: "Elms Sans", sans-serif;
    font-weight: 100; /* Peso extra fino para notas al pie */
    font-size: 0.75rem;
    color: #666666;
    margin-top: 2.5rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
</style>
<footer class="footer">
