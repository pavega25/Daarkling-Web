    viewBox="0 0 2278 156"
    preserveAspectRatio="none"
  >
    <path
      id="bouncy-path"
      d="M0-0.3C0-0.3,464,0,1139,0s1139-0.3,1139-0.3V156H0V-0.3z"></path>
  </svg>

  <div class="footer-content">
    <div class="footer-left">
      <div>
        <h3>Daarkling Tattoo</h3>
        <p>Estudio privado en Clot, Barcelona</p>
      </div>
      <div>
        <h3>Navegar</h3>
        <div class="sub-footer">
          <a href="#">Inicio</a>
          <a href="#about">Sobre mi</a>
          <a href="https://daarkling.vercel.app/tienda">Tienda</a>
        </div>
      </div>
      <div class="sub-footer">
        <h3>Redes</h3>
        <a href="https://www.instagram.com/daarkling/" target="_blank"
