          </p>

          <p class="legal-footer-note">
            Sitio web libre de rastreadores y cookies publicitarias.
          </p>
        </article>
      </div>
    </div>
  </div>
</footer>
<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { MorphSVGPlugin } from "gsap/MorphSVGPlugin"; // Requiere Club GSAP

  gsap.registerPlugin(ScrollTrigger, MorphSVGPlugin);

  function initFooterBounce() {
    // Formas del vector (Vector curvado hacia abajo vs Vector plano)
    const down = "M0-0.3C0-0.3,464,156,1139,156S2278-0.3,2278-0.3V156H0V-0.3z";
    const center = "M0-0.3C0-0.3,464,0,1139,0s1139-0.3,1139-0.3V156H0V-0.3z";

    ScrollTrigger.create({
      trigger: ".footer",
      start: "top bottom", // Inicia cuando la parte superior del footer entra por abajo de la pantalla
      onEnter: (self) => {
        // Obtenemos la velocidad del scroll del usuario
        const velocity = self.getVelocity();

        // Limitamos la variación para evitar deformaciones extremas e irrealistas
        const rawVariation = velocity / 12000;
        const variation = Math.min(Math.max(rawVariation, 0), 0.8);

        // Animar el trazo SVG con elasticidad ajustada dinámicamente
        gsap.fromTo(
          "#bouncy-path",
          { morphSVG: down },
          {
            duration: 1.8,
            morphSVG: center,
            ease: `elastic.out(${1 + variation}, ${0.4 - variation * 0.2})`,
            overwrite: "auto",
          },
        );
      },
    });
  }

  // Eventos de Astro
  document.addEventListener("DOMContentLoaded", initFooterBounce);
  document.addEventListener("astro:page-load", initFooterBounce);
</script>

<script>
  import { gsap } from "gsap";

  function initLegalModal() {
    const overlay = document.getElementById("legalModal");
    const container = overlay?.querySelector(".legal-modal-container");
    const closeBtn = document.getElementById("closeLegalModal");
    const triggers = document.querySelectorAll("[data-modal-target]");
    const articles = document.querySelectorAll(".legal-content");

    if (!overlay || !container || !closeBtn) return;

    // Abrir Modal
    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const targetId = trigger.getAttribute("data-modal-target");

        // Ocultar todas las secciones y mostrar solo la seleccionada
        articles.forEach((art) => art.classList.remove("active"));
        const targetArticle = document.getElementById(`content-${targetId}`);
        if (targetArticle) targetArticle.classList.add("active");

        // Bloquear scroll de la página
        document.body.style.overflow = "hidden";
        overlay.classList.add("open");

        // Animación GSAP de entrada
        gsap.killTweensOf([overlay, container]);
        gsap.to(overlay, { opacity: 1, duration: 0.3, ease: "power2.out" });
        gsap.fromTo(
          container,
          { y: 30, opacity: 0 },
          { y: 0, opacity: 1, duration: 0.4, ease: "power3.out", delay: 0.1 },
        );
      });
    });

    // Cerrar Modal
    function closeModal() {
      gsap.to(container, {
        y: 20,
        opacity: 0,
        duration: 0.25,
        ease: "power2.in",
      });
      gsap.to(overlay, {
        opacity: 0,
        duration: 0.3,
        ease: "power2.in",
        onComplete: () => {
          overlay.classList.remove("open");
          document.body.style.overflow = "";
        },
      });
    }

    closeBtn.addEventListener("click", closeModal);

    // Cerrar al hacer clic fuera del contenido o presionar ESC
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) closeModal();
    });

    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && overlay.classList.contains("open")) {
        closeModal();
      }
    });
  }

  // Compatibilidad con Astro
  document.addEventListener("DOMContentLoaded", initLegalModal);
  document.addEventListener("astro:page-load", initLegalModal);
</script>
