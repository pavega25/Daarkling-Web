<style>
*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  transition: none !important;
  animation: none !important;
}

:root {
  --green: #0ae448;
  --lt: #abff84;
  --black: #0e100f;
  --white: #fffce1;
  --s75: #bbbaa6;
  --s50: #7c7c6f;
  --s25: #42433d;
  --color-shockingly-green: #0ae448;
  --color-just-black: #0e100f;
  --color-surface-white: #fffce1;
  --color-lt-green: #abff84;
  --color-grey: #191919;
  --color-grey-dark: #191919;
  --color-surface75: #bbbaa6;
  --color-surface50: #7c7c6f;
  --color-surface25: #42433d;
  --gradient-macha: linear-gradient(114.41deg, var(--color-shockingly-green) 20.74%, var(--color-lt-green) 65.5%);
  --dark: var(--color-just-black);
  --light: var(--color-surface-white);
  --green: var(--color-shockingly-green);
}

.topbar {
  z-index: 300;
  position: sticky;
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 100%;
  padding: 10px;
}
h1 {
  font-size: 3rem;
}
.logo {
  font-weight: 600;
  font-size: 0.9rem;
  color: var(--white);
  z-index: 310;
}

h1 code {
  font-size: inherit;
}
.menu-toggle {
  width: 44px;
  height: 44px;
  border: none;
  background: transparent;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 310;
  position: relative;
  padding: 0;
}

/* ─── Header lo borré ─── */

code {
  font-family: Fraktion Mono, monospace;
  font-size: 0.72rem;
  background: rgba(10, 228, 72, 0.08);
  color: var(--green);
  padding: 2px 6px;
  border-radius: 3px;
}

.controls {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 16px;
  font-size: 0.72rem;
  color: var(--s50);
}
.controls label {
  display: flex;
  align-items: center;
  gap: 5px;
  cursor: pointer;
}
.controls input[type="checkbox"] {
  accent-color: var(--green);
}
.controls input[type="range"] {
  width: 64px;
  accent-color: var(--green);
}
.controls code {
  font-family: Fraktion Mono, monospace;
  font-size: 0.66rem;
  background: rgba(10, 228, 72, 0.08);
  color: var(--green);
  padding: 2px 6px;
  border-radius: 3px;
}
.speed-val {
  font-family: Fraktion Mono, monospace;
  font-size: 0.66rem;
  min-width: 2em;
}

/* ── Nav overlay ── */
.nav {
  position: fixed;
  inset: 0;
  z-index: 200;
  padding: 0.8rem;
  pointer-events: none;
  visibility: hidden;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.5rem;
}
.nav-bg {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  opacity: 0;
}

.nav-border {
  border: none;
  border-radius: 0;
}

.nav-top {
  flex: 1;
  width: 100%;
  background: white;
  color: var(--black);
  transform: translateX(-101%);
  display: flex;
  flex-direction: column;
  padding: 50px 28px 28px;
  overflow-y: auto;
  position: relative;
  z-index: 3;
  border-color: var(--black);
}

.nav-middle {
  position: relative;
  width: 100%;
  background: linear-gradient(
    135deg,
    #FFC5d3 0%,
    #E18AAA 40%,
    #FFC5d3 70%,
    #E18AAA 100%
  );
  color: var(--black);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 24px 28px;
  z-index: 2;
  min-height: 180px;
}

.nav-middle-header {
  font-family: 'Elms Sans';
  font-size: 0.8rem;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  opacity: 0.7;
  margin-bottom: 12px;
}
.img-middle-card {
  width: 100%;
  height: 350px;
  object-fit: cover;
  box-shadow: 0 0 20px rgba(0, 0, 0, 0.25);
}

.nav-panel {
  max-width: 700px
}

.nav-middle-card {
  display: flex;
  align-items: center;
  gap: 16px;
}

.nav-bottom {
  position: relative;
  height: 120px;
  width: 100%;
  background: var(--black);
  color: var(--s50);
  transform: translateX(101%);
  display: flex;
  align-items: center;
  padding: 24px 28px;
  z-index: 1;
  border-color: var(--s25);
}

.nav-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0;
  flex: 1;
  justify-content: center;
}
.nav-item {
  overflow: hidden;
}
.nav-link {
  display: block;
  text-decoration: none;
  color: var(--black);
  padding: 10px 0;
  font-size: clamp(1.5rem, 4vw, 1.8rem);
  font-weight: 600;
  line-height: 1.1;
  letter-spacing: -0.03em;
}
.nav-socials {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
}
.nav-socials a {
  font-family: 'Elms Sans';
  font-size: 1rem;
  font-weight: 700;
  color: #f5cedc;
  text-decoration: none;
}
.nav-asset {
  margin-left: auto;
}
.nav-asset img {
  position: absolute;
  bottom: 10px;
  right: 2rem;
  width: 100px;
  height: auto;
}
@media (max-width:600px) {
  .img-middle-card {
    height: 200px;
    width: 50%;
  }
}
</style>

<div class="topbar">
    <h1>Daarkling</h1>
    <button class="menu-toggle" id="menuToggle" aria-expanded="false" aria-label="Open menu">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <line class="bar bar-top" x1="3" y1="7" x2="17" y2="7" stroke="var(--white)" stroke-width="1.5" stroke-linecap="round"/>
        <line class="bar bar-mid" x1="3" y1="10" x2="17" y2="10" stroke="var(--white)" stroke-width="1.5" stroke-linecap="round"/>
        <line class="bar bar-bot" x1="3" y1="13" x2="17" y2="13" stroke="var(--white)" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
    </button>
</div>

<nav class="nav" id="nav">
  <div class="nav-bg"></div>

  <!-- Top panel — white -->
  <div class="nav-top nav-border nav-panel" id="navTop">
    <ul class="nav-list">
      <li class="nav-item"><a class="nav-link" href="#">Inicio</a></li>
      <li class="nav-item"><a class="nav-link" href="#about">Sobre mi</a></li>
      <li class="nav-item"><a class="nav-link" href="#">Tienda</a></li>
      <li class="nav-item"><a class="nav-link" href="#">Blog</a></li>
    </ul>
  </div>

  <!-- Middle panel — matcha green gradient -->
  <div class="nav-middle nav-border nav-panel" id="navMiddle">
    <div class="nav-middle-header">Novedades</div>
    <div class="nav-middle-card">
      <!-- Aquí podría poner algunas imagenes -->
       <a href="https://www.instagram.com/p/DaxIwxxjafp/?img_index=1" class="img-middle-card" target="_blank"><img class="img-middle-card" src="https://instagram.fbcn15-1.fna.fbcdn.net/v/t51.82787-15/744184571_18208389433348783_2509425452774752503_n.jpg?stp=dst-jpg_e35_tt6&_nc_cat=103&ig_cache_key=Mzk0MDk2NjYzOTY2MTkwODY4Mg%3D%3D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6IkNBUk9VU0VMX0lURU0ueHBpZHMuMjkzNC5zZHIucmVndWxhcl9waG90by5DMyJ9&_nc_ohc=g3VFtoSzzukQ7kNvwF1LzbM&_nc_oc=AdprJO5WwmkhVV5BflX03wha4L0B0NlsMBC4WzwIYssUfQCsNVJnwuoI8oeH_bDV4aE&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.fbcn15-1.fna&_nc_gid=7E1eNQE60oJe8rf-Gyq1Hg&_nc_ss=7a22e&oh=00_AQANld-d-KsH9M-8votWWgiMT44Hq92sDaUhL_1KiRKfcQ&oe=6A5D912E" alt="Ilustración digital, chica con manos en la cara"></a>
       <a href="https://www.instagram.com/p/DaLSsq3jd3S/?img_index=3" class="img-middle-card" target="_blank"><img class="img-middle-card" src="https://instagram.fbcn15-1.fna.fbcdn.net/v/t51.82787-15/735439035_18206826703348783_1455489881269920781_n.jpg?stp=dst-jpg_e35_tt6&_nc_cat=100&ig_cache_key=MzkzMDMxNTM1NDA5NjkxMzM5OQ%3D%3D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6IkNBUk9VU0VMX0lURU0ueHBpZHMuMjMxNi5zZHIucmVndWxhcl9waG90by5DMyJ9&_nc_ohc=UmMLSld4VZ0Q7kNvwFBafp0&_nc_oc=AdrPvuVu2ANtwG8NjwDxHtUXe0CGcBBsqCXke7t6Cq1qGHg3yoqjiZbCFxJX0u4J15s&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.fbcn15-1.fna&_nc_gid=7E1eNQE60oJe8rf-Gyq1Hg&_nc_ss=7a22e&oh=00_AQDtEsSpMa4P9YjZFRqsX3MK_WAfpBiuELZKUPOlAWy3Tw&oe=6A5DA833" alt="Artista sosteniendo una de sus obras"></a>
    </div>
  </div>

  <!-- Bottom panel — black -->
  <div class="nav-bottom nav-border nav-panel" id="navBottom">
    <ul class="nav-socials">
      <li><a href="https://www.instagram.com/daarkling/" target="_blank">Instagram</a></li>
      <li><a href="https://wa.me/+34601154282" target="_blank">Whatsapp</a></li>
      <li><a href="mailto:daarklingtattoo@gmail.com">Email</a></li>
    </ul>
    <div class="nav-asset">
      <img src="/favicon.png" alt=""/>
    </div>
  </div>
</nav>

<script>
    import { gsap } from "gsap";

    let isOpen = false;
    let tl = gsap.timeline();

    function openMenu() {
    tl.set("#nav", { visibility: "visible", pointerEvents: "auto" })
        .fromTo(
        ".nav-bg",
        {
        opacity: 0
        },
        {
        opacity: 1,
        duration: 0.4,
        ease: "power2.out",
        },
        0
    )
        .fromTo(
        ".nav-panel",
        { x: "101%", y: 0, rotation: 0 },
        {
            x: "0%",
            duration: 0.6,
            ease: "back.out",
            stagger: 0.2,
        },
        0
        )
        .fromTo(
        ".nav-item",
        { opacity: 0, x: -20 },
        {
            opacity: 1,
            x: 0,
            duration: 1.2,
            ease: "expo.out",
            stagger: 0.03
        },
        0.1
        )
        .fromTo(
        ".bar-top",
        {
            stroke: "var(--white)",
            attr: { x1: 3, y1: 7, x2: 17, y2: 7 }
        },
        {
            stroke: "#0e100f",
            attr: { x1: 5, y1: 5, x2: 15, y2: 15 },
            duration: 0.35,
            ease: "back.out(1.4)",
        },
        0.06
        )
        .fromTo(
        ".bar-bot",
        {
            stroke: "var(--white)",
            attr: { x1: 3, y1: 13, x2: 17, y2: 13 }
        },
        {
            stroke: "#0e100f",
            attr: { x1: 15, y1: 5, x2: 5, y2: 15 },
            duration: 0.35,
            ease: "back.out(1.4)",
        },
        0.06
        )
    }
    function closeMenu() {
    tl.to(".bar", {
        stroke: "var(--white)",
        duration: 0.2
    })
        .to(
        ".bar-top",
        {
            attr: { x1: 3, y1: 7, x2: 17, y2: 7 },
            duration: 0.2,
            ease: "power3.in"
        },
        "<"
        )
        .to(
        ".bar-bot",
        {
            attr: { x1: 3, y1: 13, x2: 17, y2: 13 },
            duration: 0.2,
            ease: "power3.in"
        },
        "<"
        )

        // panels fall
        .to(
        ".nav-panel",
        {
            y: "160vh",
            rotation: "random(-15, 15)",
            duration: 1,
            ease: "power3.in",
            stagger: {
            from: "end",
            each: 0.02
            }
        },
        "<"
        )

        // bg fades
        .to(
        ".nav-bg",
        {
            opacity: 0,
            duration: 0.3,
            ease: "power2.in"
        },
        "<0.1"
        )
        // === CAMBIO REALIZADO AQUÍ  ===
        // Desactiva los clicks y oculta el contenedor #nav al terminar de cerrar
        .set("#nav", { visibility: "hidden", pointerEvents: "none" });
    }

    function toggle() {
    isOpen = !isOpen;
    const btn = document.getElementById("menuToggle");
    btn.setAttribute("aria-expanded", isOpen);
    btn.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
    
    // === SELECCIÓN OPTIMIZADA PARA ACCESIBILIDAD ===
    // Modificamos el tabindex directamente en las anclas de ambas listas
    document
        .querySelectorAll(".nav-list a, .nav-socials a")
        .forEach((link) => link.setAttribute("tabindex", isOpen ? "0" : "-1"));
    
    tl.clear()

    if (isOpen) {
        openMenu();
    } else {
        closeMenu();
    }
    }

    document.getElementById("menuToggle").addEventListener("click", toggle);
    document.querySelector(".nav-bg").addEventListener("click", () => {
    if (isOpen) toggle();
    });
    document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && isOpen) {
        toggle();
        document.getElementById("menuToggle").focus();
    }
    });

    // === SELECCIÓN DE CLIC PARA CERRAR ===
    // Escucha el click en cualquier ancla '<a>' dentro de '.nav-list' o '.nav-socials'
    document.querySelectorAll(".nav-list a, .nav-socials a").forEach((link) => {
        link.addEventListener("click", () => {
            if (isOpen) {
                toggle();
            }
        });
    });
</script>