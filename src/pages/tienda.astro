---
import imgMeme from '../assets/images/meme.png';
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Tienda | Daarkling</title>
        <style>
            @font-face {
                font-family: 'Elms Sans';
                src: url('../assets/fonts/ElmsSans-VariableFont_wght.woff2');
            }
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }
            body {
                background-color: black;
                color: white;
                font-family: 'Elms Sans';
            }
            main {
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                text-align: center;
                height: 100dvh;
            }
            button:not(.menu-toggle) {
                padding: 16px 20px;
                margin: 10px 0;
                border-radius: 20px;
                border: none;
                cursor: pointer;
                background: #E18AAA;
                box-shadow: inset -1px -2px 10px 4px #f5cedc, inset -2px -4px 15px 15px #aa476b;
                transition: all 0.2s ease-in;
                }
                button:hover:not(.menu-toggle) {
                background: #E18AAA;
                box-shadow: inset -1px -2px 10px 4px #f5cedc, inset -2px -4px 15px 10px #aa476b, 0 0 10px white;
                transform: scale(1.05);
                }

                .btn-cta {
                text-decoration: none;
                font-family: 'Elms Sans';
                font-size: 1.2em;
                font-weight: 700;
                color: white;
            }
        </style>
    </head>
    <body>
        <main>
            <p>En construcción</p>
            <h1>Próximamente</h1>
            <img src={imgMeme.src} alt="Meme Lady Cajero">
            <button><a class="btn-cta" href="/">Volver al inicio</a></button>
        </main>
    </body>
</html>