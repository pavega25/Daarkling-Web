		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body>
        <Header/>
		<h1>{pageTitle}</h1>
        <h2>Aquí voy a publicar sobre mi ruta de aprendizaje con Astro, dame fuerza papa dios xd</h2>
        <ul>
            <li><a href="/posts/post-1/">Publicación 1</a></li>
            <li><a href="/posts/post-2/">Publicación 2</a></li>
            <li><a href="/posts/post-3/">Publicación 3</a></li>
        </ul>
		<Footer/>

		<script>
			import "../scripts/menu.js";
		</script>
